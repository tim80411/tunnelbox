{
  "name": "tunnelbox",
  "version": "1.2.0",
  "description": "Local static website management desktop application",
  "main": "./out/main/index.js",
  "bin": {
    "tunnelbox": "./out/cli/index.js"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "bump:patch": "./scripts/bump-version.sh patch",
    "bump:minor": "./scripts/bump-version.sh minor",
    "bump:major": "./scripts/bump-version.sh major",
    "setup:quick-action": "bash scripts/install-quick-action.sh",
    "cli:build": "tsup",
    "cli:dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.tunnelbox.app",
    "productName": "TunnelBox",
    "publish": {
      "provider": "github",
      "owner": "tim80411",
      "repo": "tunnelbox"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/quick-action",
        "to": "quick-action"
      },
      {
        "from": "resources/tray",
        "to": "tray"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "artifactName": "${productName}-${version}-mac-universal.${ext}",
      "protocols": [
        {
          "name": "TunnelBox",
          "schemes": [
            "tunnelbox"
          ]
        }
      ]
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-win-x64.${ext}",
      "protocols": [
        {
          "name": "TunnelBox",
          "schemes": [
            "tunnelbox"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development",
      "artifactName": "${productName}-${version}-linux-x64.${ext}"
    }
  },
  "dependencies": {
    "chokidar": "^4.0.0",
    "commander": "^14.0.3",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.8.3",
    "get-port": "^7.1.0",
    "qrcode": "^1.5.4",
    "serve-handler": "^6.1.6",
    "ws": "^8.18.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/serve-handler": "^6.1.4",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
